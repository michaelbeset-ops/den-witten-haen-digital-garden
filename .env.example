# Supabase project credentials
# Copy this file to .env and fill in your values from https://app.supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# RESEND_API_KEY is used by the Edge Function only.
# Add it as a secret in the Supabase dashboard:
# Settings → Edge Functions → Secrets → Add RESEND_API_KEY
# Do NOT put it in this file.
